rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSermon(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.speaker is string && data.speaker.size() <= 100 &&
             data.date is string && data.date.size() <= 20 &&
             data.topic is string && data.topic.size() <= 100 &&
             data.scripture is string && data.scripture.size() <= 200;
    }

    function isValidPrayerRequest(data) {
      return data.requesterName is string && data.requesterName.size() <= 100 &&
             data.text is string && data.text.size() <= 1000 &&
             data.prayedForCount is number;
    }

    match /sermons/{sermonId} {
      allow list: if true; // Publicly readable
      allow get: if true;
      allow create: if isSignedIn() && isValidId(sermonId) && isValidSermon(incoming());
      allow update: if isSignedIn() && isValidSermon(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'speaker', 'date', 'topic', 'scripture', 'videoUrl', 'audioUrl', 'sermonNotes', 'summary', 'discussionQuestions', 'socialPosts'])
      );
      allow delete: if isSignedIn(); // Add proper admin check later
    }

    match /prayerRequests/{requestId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidId(requestId) && isValidPrayerRequest(incoming()) && incoming().prayedForCount == 0;
      allow update: if isSignedIn() && isValidPrayerRequest(incoming()) && (
         incoming().diff(existing()).affectedKeys().hasOnly(['prayedForCount', 'isAnswered', 'pastorNote'])
      );
      allow delete: if isSignedIn(); // Add proper admin check later
    }
  }
}
